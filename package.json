{
  "name": "strikethroo",
  "version": "3.11.0",
  "description": "Task management for AI coding assistants",
  "main": "dist/index.js",
  "bin": {
    "strikethroo": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc && npm run build:web && npm run build:skills && npm run build:skill-prompts",
    "build:skills": "tsc --noEmit -p tsconfig.skill-scripts.json && node scripts/build-skills.cjs",
    "build:skill-prompts": "node scripts/build-skill-prompts.cjs",
    "build:web": "vite build",
    "dev": "tsc --watch",
    "dev:web": "vite",
    "dev:serve": "node --watch --require ts-node/register/transpile-only src/cli.ts serve --no-open",
    "start": "node dist/cli.js",
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "vitest run --coverage",
    "pretest:e2e": "playwright install chromium",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "capture:web": "node --require ts-node/register/transpile-only src/capture/capture-web.ts",
    "lint": "eslint 'src/**/*.{ts,tsx}'",
    "lint:fix": "eslint 'src/**/*.{ts,tsx}' --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx,css}'",
    "commitlint": "commitlint --edit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build",
    "prepare": "husky",
    "security:audit": "npm audit",
    "security:audit-json": "npm audit --json",
    "security:fix": "npm audit fix",
    "security:fix-force": "npm audit fix --force"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.css": [
      "prettier --write"
    ]
  },
  "keywords": [
    "cli",
    "task-management",
    "ai",
    "npx",
    "typescript"
  ],
  "author": "e0ipso",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.14.0"
  },
  "files": [
    "dist/",
    "dist-web/",
    "templates/",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/e0ipso/strikethroo.git"
  },
  "bugs": {
    "url": "https://github.com/e0ipso/strikethroo/issues"
  },
  "homepage": "https://github.com/e0ipso/strikethroo#readme",
  "dependencies": {
    "chalk": "^5.6.0",
    "commander": "^11.1.0",
    "diff": "^5.2.0",
    "fs-extra": "^11.3.1",
    "gray-matter": "^4.0.3",
    "inquirer": "^9.3.8"
  },
  "devDependencies": {
    "@base-ui-components/react": "^1.0.0-beta.4",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/js": "^9.34.0",
    "@modyfi/vite-plugin-yaml": "^1.1.1",
    "@playwright/test": "^1.60.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.2",
    "@semantic-release/npm": "^13.1.3",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@types/diff": "^5.2.3",
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.9",
    "@types/node": "^24.3.0",
    "@types/react": "^18.3.29",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.41.0",
    "@typescript-eslint/parser": "^8.41.0",
    "@uiw/react-codemirror": "^4.25.10",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^2.1.9",
    "clsx": "^2.1.1",
    "dompurify": "^3.4.7",
    "esbuild": "^0.28.0",
    "eslint": "^9.34.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "lucide-react": "^0.460.0",
    "marked": "^15.0.12",
    "mermaid": "^11.15.0",
    "prettier": "^3.6.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "semantic-release": "^25.0.2",
    "tailwindcss": "^4.3.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2",
    "vite": "^5.4.21",
    "vitest": "^2.1.9"
  }
}
