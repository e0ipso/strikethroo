#!/usr/bin/env bash
#
# Scaffold the canonical t3 devcontainer into the current repo, baking a
# deterministic published host port into devcontainer.json.
#
# The port is the repo directory **basename** hashed into 20000-29999 (POSIX
# cksum). It is written as a LITERAL into the scaffolded devcontainer.json
# (replacing the __T3_PORT__ placeholder), so it applies however you start the
# container -- bare `devcontainer up`, VS Code, etc. -- with no env vars and no
# ordering to get right.
#
#   cd <repo> && new-devcontainer
#   cd <repo> && rm -rf .devcontainer && new-devcontainer   # modernize / re-port
#
set -euo pipefail

template="${DEVCONTAINER_TEMPLATE_DIR:-$HOME/.config/devcontainer-templates/t3}/.devcontainer"
dest="$PWD/.devcontainer"

[[ -d "$template" ]] || { echo "Template missing: $template" >&2; exit 1; }
[[ -e "$dest" ]] && { echo ".devcontainer already exists here — run: rm -rf .devcontainer" >&2; exit 1; }

cp -R "$template" "$dest"
chmod +x "$dest"/*.sh "$dest"/scripts/*.sh 2>/dev/null || true

# Deterministic host port from the repo dir basename; freeze it into devcontainer.json.
port=$(( 20000 + $(printf '%s' "$(basename "$PWD")" | cksum | cut -d' ' -f1) % 10000 ))
node -e '
  const fs = require("fs"), f = process.argv[1], p = process.argv[2];
  const s = fs.readFileSync(f, "utf8");
  if (!s.includes("__T3_PORT__")) { console.error("placeholder __T3_PORT__ not found in " + f); process.exit(1); }
  fs.writeFileSync(f, s.replace(/__T3_PORT__/g, p));
' "$dest/devcontainer.json" "$port"

echo "Scaffolded .devcontainer (published host port $port -> container 34489)"
echo "Next: start the container (devcontainer up / VS Code), then ./.devcontainer/t3-serve.sh"
